{
  "dashboard": {
    "uid": "cc-platform",
    "title": "CC Platform Overview",
    "tags": ["cc", "spring-boot", "prometheus", "node"],
    "timezone": "browser",
    "schemaVersion": 39,
    "refresh": "30s",
    "panels": [
      {
        "title": "Service Status",
        "type": "stat",
        "gridPos": {"h": 3, "w": 24, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "up{job=~\"cc-backend|cc-frontend|cc-data-service|cc-mysql|node-backend|node-frontend|node-data\"}",
            "legendFormat": "{{job}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "value": 1, "text": "UP"},
              {"type": "value", "value": 0, "text": "DOWN"}
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "title": "JVM Heap Memory",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 3},
        "targets": [
          {"expr": "jvm_memory_used_bytes{job=\"cc-backend\", area=\"heap\"}", "legendFormat": "Used"},
          {"expr": "jvm_memory_max_bytes{job=\"cc-backend\", area=\"heap\"}", "legendFormat": "Max"},
          {"expr": "jvm_memory_committed_bytes{job=\"cc-backend\", area=\"heap\"}", "legendFormat": "Committed"}
        ],
        "fieldConfig": {"defaults": {"unit": "bytes"}}
      },
      {
        "title": "JVM GC Activity",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 3},
        "targets": [
          {"expr": "rate(jvm_gc_pause_seconds_count{job=\"cc-backend\"}[1m])", "legendFormat": "GC count/s"},
          {"expr": "rate(jvm_gc_pause_seconds_sum{job=\"cc-backend\"}[1m])", "legendFormat": "GC time/s"}
        ]
      },
      {
        "title": "HTTP Request Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 3},
        "targets": [
          {"expr": "rate(http_server_requests_seconds_count{job=\"cc-backend\"}[1m])", "legendFormat": "{{method}} {{uri}}"}
        ]
      },
      {
        "title": "DB Connection Pool",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 3},
        "targets": [
          {"expr": "hikaricp_connections_active{job=\"cc-backend\"}", "legendFormat": "Active"},
          {"expr": "hikaricp_connections_idle{job=\"cc-backend\"}", "legendFormat": "Idle"},
          {"expr": "hikaricp_connections_pending{job=\"cc-backend\"}", "legendFormat": "Pending"}
        ]
      },
      {
        "title": "Host CPU Usage",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 11},
        "targets": [
          {"expr": "100 - (avg by (server) (rate(node_cpu_seconds_total{mode=\"idle\", job=~\"node-.*\"}[1m])) * 100)", "legendFormat": "{{server}}"}
        ],
        "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
      },
      {
        "title": "Host Memory Usage",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 11},
        "targets": [
          {"expr": "(1 - (node_memory_MemAvailable_bytes{job=~\"node-.*\"} / node_memory_MemTotal_bytes{job=~\"node-.*\"})) * 100", "legendFormat": "{{server}}"}
        ],
        "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
      },
      {
        "title": "Host Disk Usage",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 11},
        "targets": [
          {"expr": "(1 - (node_filesystem_avail_bytes{job=~\"node-.*\", mountpoint=\"/\"} / node_filesystem_size_bytes{job=~\"node-.*\", mountpoint=\"/\"})) * 100", "legendFormat": "{{server}}"}
        ],
        "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
      },
      {
        "title": "Host Network Traffic",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 19},
        "targets": [
          {"expr": "rate(node_network_receive_bytes_total{job=~\"node-.*\", device!=\"lo\"}[1m])", "legendFormat": "{{server}} rx"},
          {"expr": "rate(node_network_transmit_bytes_total{job=~\"node-.*\", device!=\"lo\"}[1m])", "legendFormat": "{{server}} tx"}
        ]
      }
    ]
  }
}
